# OdaabNote 환경변수 예시
# 복사 후 .env 로 저장하고 실제 값으로 채우세요. .env는 Git에 커밋하지 마세요.

# ========== 로컬 개발용 ==========
# DB (docker-compose MySQL)
DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=password

# Google Cloud (Vision API)
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/google-vision-key.json

# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# CORS (로컬 기본값 사용 시 생략 가능)
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ========== 프로덕션 (EC2) ==========
# spring.profiles.active=prod 로 실행 시 사용
# RDS_ENDPOINT=your-rds-endpoint.ap-northeast-2.rds.amazonaws.com
# RDS_USERNAME=admin
# RDS_PASSWORD=strong-password

# ALLOWED_ORIGINS=https://your-cloudfront-id.cloudfront.net,https://your-domain.com
